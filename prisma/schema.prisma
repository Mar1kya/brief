// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id       String   @id @default(cuid())
  email    String   @unique
  password String
  name     String? 
  role     UserRole @default(USER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum BriefStatus {
  NEW
  IN_REVIEW
  ACCEPTED
  REJECTED
}

model Brief {
  id String @id @default(cuid())

  customerName           String
  customerPosition       String?
  email                  String
  phone                  String
  companyName            String  @default("ФК Полісся")
  preferredContactMethod String  @default("EMAIL")

  businessGoals   String[]
  targetAudience  String   @db.Text
  currentProblems String   @db.Text

  matchCenterFeatures String[]
  userCabinetModules  String[]
  ticketingSystem     String

  shopCategories           String   @db.Text
  paymentMethods           String[]
  needsInventoryManagement Boolean  @default(false)

  contentUpdateFrequency String
  matchResultsImport     String

  hasBrandbook      Boolean @default(false)
  designMood        String
  expectsPeakLoads  Boolean @default(false)
  estimatedDeadline String

  status BriefStatus @default(NEW)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
